DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Your site's full URL (no trailing slash). Controls whether secure cookies are used.
# Use https:// if SSL is active, http:// if not. Cart will break if this doesn't match.
# e.g. https://www.naptrio.com  OR  http://naptrio.milesweb.in
SITE_URL=http://your-site.milesweb.in

# Gmail SMTP — use an App Password, not your actual Gmail password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
